# Copy this file to .env and adjust values before running docker compose.
# docker compose automatically loads a .env file in the project root.

# Secret used by the jwt_auth plugin (referenced by config.yml's secret_env).
# Required - docker compose will refuse to start without it.
JWT_SECRET=changeme

# How often the gateway polls config.yml for changes.
DEALER_CONFIG_POLL_INTERVAL=2s
